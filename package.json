{
  "name": "delpueblo-caja",
  "version": "1.0.9",
  "description": "Caja registradora local para panadería (offline). Electron + React + SQLite + balanza Systel + impresora térmica Xprinter 58mm.",
  "author": {
    "name": "DEL PUEBLO",
    "email": "caja@delpueblo.app"
  },
  "license": "UNLICENSED",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3,serialport,@grandchef/node-printer",
    "postinstall": "patch-package && electron-builder install-app-deps"
  },
  "dependencies": {
    "@grandchef/node-printer": "~0.8.0",
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.8.9",
    "node-thermal-printer": "^4.4.4",
    "serialport": "^12.0.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "patch-package": "^8.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "node-gyp": "^10.2.0"
  }
}

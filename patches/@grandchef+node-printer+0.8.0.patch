+// Parcheado (patch-package): cargamos el binario nativo directamente en vez de
+// usar @mapbox/node-pre-gyp para ubicarlo. Evita depender de node-pre-gyp en
+// runtime (falla al resolver rutas dentro del asar de Electron) y elimina el
+// node-gyp viejo que arrastraba. El binario queda en ./node_printer.node por el
+// paso action_after_build del binding.gyp (module_path = "./lib/").
+module.exports = exports = require('./node_printer.node');

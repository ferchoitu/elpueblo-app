# --- Supabase (mismo proyecto donde la caja hace push) ---
# URL del proyecto, ej: https://xxxx.supabase.co
SUPABASE_URL=
# Service role key (Settings → API → service_role). SECRETA: solo server-side.
SUPABASE_SERVICE_ROLE_KEY=

# --- Acceso al dashboard (contraseña simple) ---
# La contraseña para entrar.
DASHBOARD_PASSWORD=
# Secreto para firmar la cookie de sesión (poné algo largo y al azar).
DASHBOARD_SESSION_SECRET=
